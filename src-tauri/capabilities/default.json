{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "clipboard-manager:default",
    "sql:default",
    "store:default",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-open"
  ]
}
